// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  phone        String   @unique
  name         String?
  upiId        String   @unique
  pin          String   // bcrypt hashed
  avatarUrl    String?
  kycStatus    String   @default("pending") // pending | verified | rejected
  role         String   @default("user")   // user | merchant | admin
  referralCode String   @unique
  referredBy   String?
  walletBalance Float   @default(1000)    // start with ₹1000 demo balance
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bankAccounts   BankAccount[]
  sentTx         Transaction[] @relation("sender")
  receivedTx     Transaction[] @relation("receiver")
  rewards        Reward[]
  otps           OTP[]
  notifications  Notification[]
  merchantProfile Merchant?

  @@map("users")
}

model OTP {
  id        String   @id @default(uuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [phone], references: [phone])

  @@map("otps")
}

model BankAccount {
  id                    String   @id @default(uuid())
  userId                String
  bankName              String
  accountNumber         String
  ifscCode              String
  accountHolder         String
  branchName            String?  // auto-filled from IFSC lookup
  isDefault             Boolean  @default(false)
  isLinked              Boolean  @default(true)
  verificationStatus    String   @default("pending") // pending | verified | failed
  razorpayContactId     String?  // Razorpay Contact ID for payouts
  razorpayFundAccountId String?  // Razorpay Fund Account ID for payouts
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model Transaction {
  id             String   @id @default(uuid())
  senderId       String
  receiverId     String
  amount         Float
  description    String?
  upiRef         String   @unique @default(uuid())
  status         String   @default("pending") // pending | success | failed
  type           String   @default("transfer") // transfer | qr_pay | wallet_load | wallet_withdraw | cashback
  cashbackAmount Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sender   User @relation("sender",   fields: [senderId],   references: [id])
  receiver User @relation("receiver", fields: [receiverId], references: [id])

  @@map("transactions")
}

model Merchant {
  id             String   @id @default(uuid())
  userId         String   @unique
  businessName   String
  businessType   String
  upiId          String   @unique
  totalEarnings  Float    @default(0)
  pendingSettlement Float @default(0)
  createdAt      DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlements Settlement[]

  @@map("merchants")
}

model Settlement {
  id         String   @id @default(uuid())
  merchantId String
  amount     Float
  status     String   @default("pending") // pending | processing | completed
  settledAt  DateTime?
  createdAt  DateTime @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("settlements")
}

model Reward {
  id          String   @id @default(uuid())
  userId      String
  amount      Float
  type        String   // cashback | referral_bonus | welcome
  description String?
  txId        String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rewards")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // payment | alert | promo
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
